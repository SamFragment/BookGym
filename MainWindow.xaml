<Window x:Class="BookGym.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BookGym"
        mc:Ignorable="d"
        Title="MainWindow" Height="500" Width="800">
    <Grid Background="#0D2626" Margin="0,0,0,-16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5*"/>
            <ColumnDefinition Width="11*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="20">
            <TextBlock Text="Gym Booker"
                       Foreground="#00FF00"
                       FontSize="28"
                       FontFamily="Segoe UI"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,10"/>

            <!-- <Image Source="spartan.png"
                   Stretch="Uniform"
                   HorizontalAlignment="Center"/> -->

            <!-- Target Section -->
            <Border Background="#1E1E1E"
                    BorderBrush="#00FF00"
                    BorderThickness="2"
                    Padding="15"
                    Margin="0,20,0,0"
                    CornerRadius="5">
                <StackPanel>
                    <TextBlock Text="Target"
                               Foreground="#00FF00"
                               FontSize="20"
                               FontWeight="Bold"
                               FontFamily="Segoe UI"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,10"/>

                    <StackPanel Orientation="Horizontal" Margin="0,5" VerticalAlignment="Center">
                        <TextBlock Text="Class: "
                                   Foreground="#00FF00"
                                   FontSize="14"
                                   FontFamily="Consolas"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                        <TextBox x:Name="TargetClassName"
                                 Text="Circuit Training"
                                 Foreground="#FFFFFF"
                                 Background="#2E2E2E"
                                 BorderBrush="#00FF00"
                                 BorderThickness="1"
                                 FontSize="14"
                                 FontFamily="Consolas"
                                 Margin="5,0,0,0"
                                 Padding="5"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,5" VerticalAlignment="Center">
                        <TextBlock Text="Date: "
                                   Foreground="#00FF00"
                                   FontSize="14"
                                   FontFamily="Consolas"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                        <DatePicker x:Name="TargetDate"
                                    Margin="5,0,0,0"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <TextBlock Text="Time: "
                                   Foreground="#00FF00"
                                   FontSize="14"
                                   FontFamily="Consolas"
                                   FontWeight="Bold"/>
                        <TextBlock x:Name="TargetTime"
                                   Text="6:00 PM"
                                   Foreground="#FFFFFF"
                                   FontSize="14"
                                   FontFamily="Consolas"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>

        <TextBox x:Name="ConsoleOutput"
                 Grid.Column="1"
                 Margin="20,20,20,30"
                 Background="#1E1E1E"
                 Foreground="#00FF00"
                 FontFamily="Consolas"
                 FontSize="12"
                 IsReadOnly="True"
                 BorderThickness="1"
                 BorderBrush="#555555"
                 Padding="10"
                 TextWrapping="Wrap"
                 AcceptsReturn="True"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"/>

    </Grid>
</Window>
